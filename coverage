/* ============================================================================
   3. STORAGE
   ============================================================================ */

function save() {
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state.coverage));
    const ts = new Date().toLocaleTimeString();
    const el = document.getElementById('lastSaved');
    if (el) el.textContent = 'saved · ' + ts;
  } catch (err) {
    toast('Storage error', err.message, 'error');
  }
}

function load() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (!raw) return null;
    return JSON.parse(raw);
  } catch {
    return null;
  }
}

/**
 * Build a flat list of every T-code (technique + sub-technique) with parent links.
 */
function flatTechniques() {
  const out = [];
  for (const t of TECHNIQUES) {
    out.push({ ...t, isSub: false });
    if (t.sub) {
      for (const s of t.sub) {
        out.push({ ...s, tactics: t.tactics, isSub: true, parent: t.id });
      }
    }
  }
  return out;
}

/**
 * Seed initial coverage records for all known techniques.
 */
function seedCoverage() {
  for (const t of flatTechniques()) {
    if (!state.coverage[t.id]) {
      state.coverage[t.id] = defaultCoverage(t.id, t.name);
    } else {
      // ensure name kept in sync if dataset updated
      state.coverage[t.id].name = t.name;
    }
  }
}

/**
 * Mock dataset — populates roughly half the matrix with realistic-looking coverage
 * so the UI has something compelling on first run.
 */
function loadSampleDataset() {
  const flats = flatTechniques();
  const statuses = ['full', 'partial', 'minimal', 'none', 'planned', 'fp', 'none', 'none', 'partial', 'minimal'];
  for (let i = 0; i < flats.length; i++) {
    const t = flats[i];
    // skew distribution to be realistic — most things are partial/none
    const r = Math.random();
    let status;
    if (r < 0.18) status = 'full';
    else if (r < 0.42) status = 'partial';
    else if (r < 0.55) status = 'minimal';
    else if (r < 0.62) status = 'planned';
    else if (r < 0.66) status = 'fp';
    else status = 'none';

    const rec = state.coverage[t.id] || defaultCoverage(t.id, t.name);
    rec.status = status;
    rec.owner = SAMPLE_OWNERS[i % SAMPLE_OWNERS.length];
    rec.rules = (SAMPLE_RULES[i % SAMPLE_RULES.length] || []).join(', ');
    rec.sources = (SAMPLE_SOURCES[i % SAMPLE_SOURCES.length] || []).join(', ');
    rec.reviewed = randomRecentDate();

    // Realistic signal scoring based on status
    const baseline = {
      full:    [85, 80, 90, 85, 80, 60, 85, 75],
      partial: [65, 55, 70, 60, 50, 30, 55, 50],
      minimal: [35, 30, 45, 40, 25, 15, 30, 25],
      planned: [15, 10, 20, 15, 10, 10, 5, 5],
      fp:      [50, 25, 70, 60, 50, 20, 40, 70],
      none:    [0, 0, 10, 10, 0, 0, 0, 0],
    }[status];

    const keys = ['fidelity','reliability','telemetry','dataSources','depth','prevention','testing','frequency'];
    keys.forEach((k, idx) => {
      const variance = (Math.random() - 0.5) * 20;
      rec.signals[k] = Math.max(0, Math.min(100, Math.round(baseline[idx] + variance)));
    });

    if (status === 'full' || status === 'partial') {
      rec.logic = `// example detection logic for ${t.id}\ndataset=xdr_data\n| filter event_type = ENUM.PROCESS\n| filter action_process_image_name in ("powershell.exe","pwsh.exe")\n| filter action_process_image_command_line contains "-enc"`;
    }

    state.coverage[t.id] = rec;
  }
}

function randomRecentDate() {
  const days = Math.floor(Math.random() * 60);
  const d = new Date();
  d.setDate(d.getDate() - days);
  return d.toISOString().split('T')[0];
}


/* ============================================================================
   4. SCORING ENGINE
   ============================================================================
   Coverage % is a weighted sum of 8 detection signals.
   Weights reflect what detection engineers actually care about: fidelity and
   reliability matter most (a noisy alert that fires constantly is worse than
   nothing); telemetry and data sources are foundational; testing validates
   reality vs assumption.
   ============================================================================ */

const SIGNAL_WEIGHTS = {
  fidelity:    0.20,
  reliability: 0.18,
  telemetry:   0.15,
  dataSources: 0.12,
  depth:       0.10,
  testing:     0.10,
  frequency:   0.08,
  prevention:  0.07,
};

const SIGNAL_LABELS = {
  fidelity:    'Detection Fidelity',
  reliability: 'Alert Reliability',
  telemetry:   'Telemetry Quality',
  dataSources: 'Data Source Availability',
  depth:       'Detection Depth',
  prevention:  'Prevention Capability',
  testing:     'Testing & Validation',
  frequency:   'Detection Frequency',
};

function computeCoverage(record) {
  if (!record || !record.signals) return 0;
  let total = 0;
  for (const [k, w] of Object.entries(SIGNAL_WEIGHTS)) {
    total += (record.signals[k] || 0) * w;
  }
  // Status-based modifier — explicit "none" caps the score
  if (record.status === 'none') total = Math.min(total, 5);
  return Math.round(total);
}

function statusFromScore(score) {
  if (score >= 80) return 'full';
  if (score >= 55) return 'partial';
  if (score >= 25) return 'minimal';
  if (score >= 10) return 'planned';
  return 'none';
}


