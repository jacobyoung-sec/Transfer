function init() {
  // 1. Seed defaults for every known technique
  seedCoverage();

  // 2. Hydrate from localStorage if present
  const stored = load();
  if (stored) {
    for (const [k, v] of Object.entries(stored)) {
      if (state.coverage[k]) state.coverage[k] = { ...state.coverage[k], ...v };
      else state.coverage[k] = v;
    }
  } else {
    // First run — auto-load the sample dataset
    loadSampleDataset();
    save();
  }

  // 3. Render
  renderAll();
}

</script>
