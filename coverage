      if (e.key === '2') switchView('matrix');
      if (e.key === '3') switchView('analytics');
      if (e.key === '4') switchView('io');
    }
  });

  document.getElementById('btnHelp').addEventListener('click', modalHelp);

  // Init
  init();
});

