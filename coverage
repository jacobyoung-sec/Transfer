T1078.002, partial, blue-team-alpha, XSIAM-CR-042
T1003.001, full, detection-eng, XSIAM-CR-088, EDR"></textarea>
    `,
    `
    <button class="btn" id="mCancel">Cancel</button>
    <button class="btn btn-primary" id="mImport">Import</button>
    `
  );
  document.getElementById('mCancel').onclick = hideModal;
  document.getElementById('mImport').onclick = () => {
    const lines = document.getElementById('pasteArea').value.trim().split('\n').filter(Boolean);
    let added = 0, updated = 0;
    for (const line of lines) {
      const parts = line.split(',').map(p => p.trim());
      const tcode = parts[0].toUpperCase();
      if (!/^T\d{4}(\.\d{3})?$/.test(tcode)) continue;
      if (!state.coverage[tcode]) {
        state.coverage[tcode] = defaultCoverage(tcode, tcode);
        added++;
