function renderTacticBars() {
  const wrap = document.getElementById('tacticBars');
  wrap.innerHTML = '';
  for (const tactic of TACTICS) {
    const techs = TECHNIQUES.filter(t => t.tactics.includes(tactic.id));
    const total = techs.length;
    let weighted = 0;
    for (const t of techs) {
      const rec = state.coverage[t.id];
      if (!rec) continue;
      const score = computeCoverage(rec) / 100;
      weighted += score;
    }
    const pct = total ? Math.round(weighted / total * 100) : 0;
    const color = pct >= 70 ? 'var(--status-full)' : pct >= 40 ? 'var(--status-partial)' : pct >= 20 ? 'var(--status-minimal)' : 'var(--status-none)';

    const row = document.createElement('div');
    row.className = 'tactic-bar-row';
    row.innerHTML = `
      <div class="name">${tactic.name}</div>
      <div class="tactic-bar-track"><div class="tactic-bar-fill" style="width:${pct}%;background:${color}"></div></div>
      <div class="pct">${pct}%</div>
    `;
    wrap.appendChild(row);
  }
}

