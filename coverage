function exportJSON() {
  const data = {
    exportedAt: new Date().toISOString(),
    attackVersion: '17',
    coverage: state.coverage,
  };
  download('sentinel-coverage.json', JSON.stringify(data, null, 2), 'application/json');
  toast('Exported', 'sentinel-coverage.json downloaded', 'success');
}

function exportCSV() {
  const headers = ['tcode','name','status','owner','reviewed','rules','sources','score',
                   ...Object.keys(SIGNAL_WEIGHTS), 'notes'];
  const rows = [headers.join(',')];
  for (const r of Object.values(state.coverage)) {
    const score = computeCoverage(r);
    const vals = [
      r.tcode, q(r.name), r.status, q(r.owner||''), r.reviewed||'', q(r.rules||''), q(r.sources||''), score,
      ...Object.keys(SIGNAL_WEIGHTS).map(k => r.signals[k] || 0),
      q(r.notes||'')
    ];
    rows.push(vals.join(','));
  }
  download('sentinel-coverage.csv', rows.join('\n'), 'text/csv');
  toast('Exported', 'sentinel-coverage.csv downloaded', 'success');
}

function q(s) {
  if (s === null || s === undefined) return '';
  s = String(s);
  if (s.includes(',') || s.includes('"') || s.includes('\n')) {
    return '"' + s.replace(/"/g, '""') + '"';
  }
  return s;
}

function exportNavigatorLayer() {
  const colorMap = {
    full:    '#10b981',
    partial: '#eab308',
    minimal: '#f97316',
    none:    '#ef4444',
    fp:      '#a855f7',
    planned: '#3b82f6',
  };
  const techniques = [];
  for (const r of Object.values(state.coverage)) {
    if (r.status === 'none' && !r.owner && !r.rules) continue; // skip empty
    const score = computeCoverage(r);
    techniques.push({
      techniqueID: r.tcode,
      score: score,
      color: colorMap[r.status],
      comment: `[${STATUS_META[r.status].label}] ${r.owner ? 'owner: ' + r.owner + ' · ' : ''}${r.rules ? 'rules: ' + r.rules : ''}`,
      enabled: true,
    });
  }
  const layer = {
    name: 'SENTINEL Coverage Export',
    versions: { attack: '17', navigator: '5.1.0', layer: '4.5' },
    domain: 'enterprise-attack',
    description: 'Detection coverage exported from SENTINEL on ' + new Date().toISOString(),
    expandedSubtechniques: 'all',
    techniques,
    gradient: {
      colors: ['#ef4444', '#f97316', '#eab308', '#10b981'],
      minValue: 0,
      maxValue: 100,
    },
    legendItems: Object.entries(STATUS_META).map(([k, v]) => ({ label: v.label, color: colorMap[k] })),
  };
  download('sentinel-navigator-layer.json', JSON.stringify(layer, null, 2), 'application/json');
  toast('Layer exported', 'Upload to ATT&CK Navigator', 'success');
}

function download(filename, content, type) {
  const blob = new Blob([content], { type });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = filename;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
}

function handleFileImport(file) {
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    const txt = e.target.result;
    try {
      if (file.name.endsWith('.json')) {
        const data = JSON.parse(txt);
        if (data.coverage) {
          Object.assign(state.coverage, data.coverage);
        } else if (data.techniques) {
          // Navigator layer format
          for (const t of data.techniques) {
            const tc = t.techniqueID;
            if (!state.coverage[tc]) state.coverage[tc] = defaultCoverage(tc, t.comment || tc);
            if (t.color === '#10b981') state.coverage[tc].status = 'full';
            else if (t.color === '#eab308') state.coverage[tc].status = 'partial';
            else if (t.color === '#f97316') state.coverage[tc].status = 'minimal';
            else if (t.color === '#3b82f6') state.coverage[tc].status = 'planned';
            else if (t.color === '#a855f7') state.coverage[tc].status = 'fp';
            if (t.comment) state.coverage[tc].notes = t.comment;
          }
        }
      } else if (file.name.endsWith('.csv')) {
        const lines = txt.split('\n').filter(Boolean);
        const headers = lines[0].split(',').map(h => h.trim().toLowerCase());
        const tIdx = headers.indexOf('tcode');
        const sIdx = headers.indexOf('status');
        for (let i = 1; i < lines.length; i++) {
          const parts = parseCSVLine(lines[i]);
          const tc = parts[tIdx];
          if (!/^T\d{4}/.test(tc)) continue;
          if (!state.coverage[tc]) state.coverage[tc] = defaultCoverage(tc, tc);
          if (sIdx >= 0 && STATUS_META[parts[sIdx]]) state.coverage[tc].status = parts[sIdx];
        }
      }
      save();
      renderAll();
      toast('Import complete', `Loaded from ${file.name}`, 'success');
    } catch (err) {
      toast('Import failed', err.message, 'error');
    }
  };
  reader.readAsText(file);
}

function parseCSVLine(line) {
  const out = [];
  let cur = '', inQ = false;
  for (let i = 0; i < line.length; i++) {
    const ch = line[i];
    if (inQ) {
      if (ch === '"' && line[i+1] === '"') { cur += '"'; i++; }
      else if (ch === '"') inQ = false;
      else cur += ch;
    } else {
      if (ch === '"') inQ = true;
      else if (ch === ',') { out.push(cur); cur = ''; }
      else cur += ch;
    }
  }
  out.push(cur);
  return out.map(s => s.trim());
}


