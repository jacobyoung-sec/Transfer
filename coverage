/* --- Matrix view --- */
function renderMatrix() {
  const matrix = document.getElementById('matrix');
  matrix.innerHTML = '';
  const search = state.filters.search.toLowerCase();
  const statusFilter = state.filters.statuses;

  for (const tactic of TACTICS) {
    const col = document.createElement('div');
    col.className = 'tactic-col';

    const techs = TECHNIQUES.filter(t => t.tactics.includes(tactic.id));
    const visible = techs.filter(t => {
      const rec = state.coverage[t.id];
      if (search) {
        const m = t.id.toLowerCase().includes(search) || t.name.toLowerCase().includes(search) ||
                  (rec.owner||'').toLowerCase().includes(search) || (rec.rules||'').toLowerCase().includes(search);
        if (!m) return false;
      }
      if (statusFilter.size > 0) {
        return statusFilter.has(rec.status);
      }
      return true;
    });

    col.innerHTML = `
      <div class="tactic-header">
        <div class="tactic-name">${tactic.name}</div>
        <div class="tactic-meta">
          <span>${tactic.code}</span>
          <span>${visible.length}/${techs.length}</span>
        </div>
      </div>
      <div class="technique-list" id="tl-${tactic.id}"></div>
    `;
    matrix.appendChild(col);

    const list = col.querySelector('.technique-list');
    for (const t of visible) {
      list.appendChild(makeTechniqueCard(t));
    }

    if (visible.length === 0) {
      list.innerHTML = '<div style="font-size:11px;color:var(--text-faint);padding:8px;text-align:center;font-family:var(--font-mono)">— no matches</div>';
    }
  }
}

function makeTechniqueCard(t) {
  const rec = state.coverage[t.id];
  const card = document.createElement('div');
  card.className = 'technique-card';
  card.dataset.status = rec.status;
  card.dataset.tcode = t.id;

  const subCount = (t.sub || []).length;
  card.innerHTML = `
    ${subCount ? `<span class="sub-indicator">+${subCount}</span>` : ''}
    <div class="tcode">${t.id}</div>
    <div class="tname">${t.name}</div>
    ${subCount ? `<div class="subtechnique-list"></div>` : ''}
  `;

  card.addEventListener('click', e => {
    e.stopPropagation();
    openDetail(t.id);
  });

  if (subCount) {
    card.addEventListener('dblclick', e => {
      e.stopPropagation();
      card.classList.toggle('expanded');
      const list = card.querySelector('.subtechnique-list');
      if (card.classList.contains('expanded') && !list.children.length) {
        for (const s of t.sub) {
          const subRec = state.coverage[s.id];
          const sub = document.createElement('div');
          sub.className = 'subtechnique-card';
          sub.dataset.status = subRec.status;
          sub.innerHTML = `<span class="tcode">${s.id}</span><span class="tname">${s.name}</span>`;
          sub.addEventListener('click', ev => {
            ev.stopPropagation();
            openDetail(s.id);
          });
          list.appendChild(sub);
        }
      }
    });
  }

  // Tooltip
  card.addEventListener('mouseenter', e => showTooltip(t, e));
  card.addEventListener('mouseleave', hideTooltip);
  card.addEventListener('mousemove', e => moveTooltip(e));

  return card;
}

/* --- Tooltip --- */
const tooltipEl = document.getElementById('tooltip');
function showTooltip(t, e) {
  const rec = state.coverage[t.id];
  const score = computeCoverage(rec);
  tooltipEl.innerHTML = `
    <div class="name">${t.id} · ${t.name}</div>
    <div class="desc">${t.desc || ''}</div>
    <div style="margin-top:6px;font-family:var(--font-mono);font-size:10px;color:var(--text-muted)">
      ${STATUS_META[rec.status].label.toUpperCase()} · score ${score}% · ${rec.owner || 'unassigned'}
    </div>
  `;
  tooltipEl.classList.add('show');
  moveTooltip(e);
}
function moveTooltip(e) {
  const rect = tooltipEl.getBoundingClientRect();
  let x = e.clientX + 14;
  let y = e.clientY + 14;
  if (x + rect.width > window.innerWidth) x = e.clientX - rect.width - 14;
  if (y + rect.height > window.innerHeight) y = e.clientY - rect.height - 14;
  tooltipEl.style.left = x + 'px';
  tooltipEl.style.top  = y + 'px';
}
function hideTooltip() { tooltipEl.classList.remove('show'); }


