    <div class="sidebar-footer">
      <div>build 2026.05 · local</div>
      <div id="lastSaved">unsaved</div>
    </div>
  </aside>

  <!-- MAIN -->
  <main class="main">

    <!-- DASHBOARD VIEW -->
    <section class="view active" id="view-dashboard">
      <div class="view-header">
        <div>
          <div class="view-title">Detection Coverage Overview</div>
          <div class="view-subtitle" id="dashSubtitle">— TTPs · — fully covered · last review —</div>
        </div>
        <div class="view-toolbar">
          <button class="btn" id="btnRefreshDash">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
