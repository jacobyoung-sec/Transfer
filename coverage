function renderRiskList() {
  const wrap = document.getElementById('riskList');
  // Risk = uncovered/minimal techniques weighted by tactic priority
  const tacticWeight = {
    'initial-access': 5, 'execution': 5, 'persistence': 4, 'credential-access': 5,
    'lateral-movement': 4, 'impact': 5, 'privilege-escalation': 4, 'command-and-control': 4,
    'defense-evasion': 3, 'collection': 2, 'exfiltration': 3, 'discovery': 2,
    'reconnaissance': 1, 'resource-development': 1,
  };
  const all = flatTechniques()
    .filter(t => !t.isSub) // top-level only for the dashboard
    .map(t => {
      const rec = state.coverage[t.id];
      const score = computeCoverage(rec);
      const weight = Math.max(...t.tactics.map(tac => tacticWeight[tac] || 1));
      const risk = (100 - score) * weight / 100;
      return { t, rec, score, risk };
    })
    .filter(x => x.score < 40)
    .sort((a, b) => b.risk - a.risk)
    .slice(0, 8);

  wrap.innerHTML = '';
  if (all.length === 0) {
    wrap.innerHTML = '<div class="empty">All techniques have moderate or better coverage. 🎯</div>';
    return;
  }
  for (const r of all) {
    const sev = r.risk > 4 ? 'critical' : r.risk > 2.5 ? 'high' : 'medium';
    const div = document.createElement('div');
    div.className = 'risk-item';
    div.innerHTML = `
      <span class="tcode">${r.t.id}</span>
      <span class="name">${r.t.name}</span>
      <span class="severity ${sev}">${sev.toUpperCase()}</span>
    `;
    div.addEventListener('click', () => { switchView('matrix'); setTimeout(() => openDetail(r.t.id), 250); });
    wrap.appendChild(div);
  }
}

function renderDonut(counts, total) {
  const wrap = document.getElementById('donutWrap');
  const order = ['full','partial','minimal','planned','fp','none'];
  const cx = 60, cy = 60, r = 42, sw = 16;
  const c = 2 * Math.PI * r;

  let offset = 0;
  const segments = order.map(k => {
    const v = counts[k] || 0;
    const len = total ? (v / total) * c : 0;
    const seg = `<circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="${STATUS_META[k].color}" stroke-width="${sw}" stroke-dasharray="${len} ${c}" stroke-dashoffset="${-offset}" transform="rotate(-90 ${cx} ${cy})"/>`;
    offset += len;
    return seg;
  }).join('');

  wrap.innerHTML = `
    <svg width="120" height="120" viewBox="0 0 120 120">
      <circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="var(--bg-elevated)" stroke-width="${sw}"/>
      ${segments}
      <text x="${cx}" y="${cy+4}" text-anchor="middle" font-family="IBM Plex Mono" font-size="14" font-weight="500" fill="var(--text-primary)">${total}</text>
    </svg>
    <div class="donut-legend">
      ${order.map(k => `
        <div class="legend-row">
          <span class="legend-swatch" style="background:${STATUS_META[k].color}"></span>
          <span class="label">${STATUS_META[k].label}</span>
          <span class="value">${counts[k] || 0}</span>
        </div>
      `).join('')}
    </div>
  `;
}

