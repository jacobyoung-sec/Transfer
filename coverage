function openDetail(tcode) {
  const t = flatTechniques().find(x => x.id === tcode);
  if (!t) return;
  const rec = state.coverage[tcode];
  state.selectedTechnique = tcode;

  document.getElementById('detailTCode').textContent = t.id;
  document.getElementById('detailName').textContent = t.name;
  document.getElementById('detailDesc').textContent = t.desc || '—';

  const tacticsEl = document.getElementById('detailTactics');
  tacticsEl.innerHTML = t.tactics.map(id => {
    const tac = TACTICS.find(x => x.id === id);
    return `<span class="panel-tactic">${tac ? tac.name : id}</span>`;
  }).join('');

  // Status grid
  const sg = document.getElementById('statusGrid');
  sg.innerHTML = '';
  for (const [key, meta] of Object.entries(STATUS_META)) {
    const pill = document.createElement('div');
    pill.className = 'status-pill' + (rec.status === key ? ' selected' : '');
    pill.style.color = meta.color;
    pill.innerHTML = `<span class="dot" style="background:${meta.color}"></span><span style="color:var(--text-primary)">${meta.label}</span>`;
    pill.addEventListener('click', () => {
      rec.status = key;
      openDetail(tcode);  // re-render
    });
    sg.appendChild(pill);
  }

  // Signal sliders
  const sl = document.getElementById('signalSliders');
  sl.innerHTML = '';
  for (const [key, label] of Object.entries(SIGNAL_LABELS)) {
    const row = document.createElement('div');
    row.className = 'field';
    const val = rec.signals[key] || 0;
    row.innerHTML = `
      <div class="score-row"><span style="color:var(--text-secondary);font-family:var(--font-sans);font-size:11px">${label}</span><span class="val">${val}</span></div>
      <input class="score-slider" type="range" min="0" max="100" value="${val}" data-signal="${key}" />
    `;
    const slider = row.querySelector('input');
    const valEl = row.querySelector('.val');
    slider.addEventListener('input', e => {
      const v = parseInt(e.target.value, 10);
      rec.signals[key] = v;
      valEl.textContent = v;
      updateComputed(rec);
    });
    sl.appendChild(row);
  }
  updateComputed(rec);

  // Fields
  document.getElementById('fldOwner').value = rec.owner || '';
  document.getElementById('fldReviewed').value = rec.reviewed || '';
  document.getElementById('fldRules').value = rec.rules || '';
  document.getElementById('fldSources').value = rec.sources || '';
  document.getElementById('fldLogic').value = rec.logic || '';
  document.getElementById('fldNotes').value = rec.notes || '';

  document.getElementById('detailPanel').classList.add('open');
}

function updateComputed(rec) {
  const score = computeCoverage(rec);
  document.getElementById('computedScore').textContent = score + '%';
  document.getElementById('computedFill').style.width = score + '%';
}

function closeDetail() {
  document.getElementById('detailPanel').classList.remove('open');
  state.selectedTechnique = null;
}

function saveDetail() {
  const tcode = state.selectedTechnique;
  if (!tcode) return;
  const rec = state.coverage[tcode];

  rec.owner = document.getElementById('fldOwner').value;
  rec.reviewed = document.getElementById('fldReviewed').value;
  rec.rules = document.getElementById('fldRules').value;
  rec.sources = document.getElementById('fldSources').value;
  rec.logic = document.getElementById('fldLogic').value;
  rec.notes = document.getElementById('fldNotes').value;

  save();
  renderAll();
  toast('Saved', `${tcode} coverage updated`, 'success');
}

function deleteDetail() {
  const tcode = state.selectedTechnique;
  if (!tcode) return;
  // Don't actually remove the record — just reset it
  state.coverage[tcode] = defaultCoverage(tcode, state.coverage[tcode].name);
  save();
  renderAll();
  closeDetail();
  toast('Reset', `${tcode} coverage cleared`, 'info');
}


