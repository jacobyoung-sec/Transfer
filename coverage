function renderMaturityChart() {
  const wrap = document.getElementById('maturityChart');
  // Bucket scores 0-20, 21-40, 41-60, 61-80, 81-100
  const buckets = [0, 0, 0, 0, 0];
  const labels  = ['0–20', '21–40', '41–60', '61–80', '81–100'];
  for (const r of Object.values(state.coverage)) {
    const s = computeCoverage(r);
    if (s <= 20) buckets[0]++;
    else if (s <= 40) buckets[1]++;
    else if (s <= 60) buckets[2]++;
    else if (s <= 80) buckets[3]++;
    else buckets[4]++;
  }
  const max = Math.max(...buckets, 1);
  const W = 280, H = 160, pad = 24;
  const bw = (W - pad * 2) / buckets.length;
  let bars = '';
  buckets.forEach((v, i) => {
    const h = (v / max) * (H - pad * 2);
    const x = pad + i * bw;
    const y = H - pad - h;
    const color = i === 0 ? 'var(--status-none)' : i === 1 ? 'var(--status-minimal)' : i === 2 ? 'var(--status-partial)' : i === 3 ? 'var(--status-partial)' : 'var(--status-full)';
    bars += `
      <rect x="${x + 4}" y="${y}" width="${bw - 8}" height="${h}" fill="${color}" rx="2"/>
      <text x="${x + bw / 2}" y="${y - 4}" text-anchor="middle" font-family="IBM Plex Mono" font-size="10" fill="var(--text-secondary)">${v}</text>
      <text x="${x + bw / 2}" y="${H - 8}" text-anchor="middle" font-family="IBM Plex Mono" font-size="10" fill="var(--text-muted)">${labels[i]}</text>
    `;
  });
  wrap.innerHTML = `<svg width="100%" height="${H}" viewBox="0 0 ${W} ${H}">${bars}</svg>`;
}

function renderScatterChart() {
  const wrap = document.getElementById('scatterChart');
  const W = 280, H = 200, pad = 28;
  const pts = Object.values(state.coverage).map(r => {
    const conf = (r.signals.reliability + r.signals.fidelity) / 2;
    const mat = (r.signals.testing + r.signals.depth) / 2;
    return { conf, mat, status: r.status };
  });

  const axes = `
    <line x1="${pad}" y1="${H - pad}" x2="${W - pad}" y2="${H - pad}" stroke="var(--border)" stroke-width="1"/>
    <line x1="${pad}" y1="${pad}" x2="${pad}" y2="${H - pad}" stroke="var(--border)" stroke-width="1"/>
    <text x="${W / 2}" y="${H - 6}" text-anchor="middle" font-family="IBM Plex Mono" font-size="9" fill="var(--text-muted)">MATURITY →</text>
    <text x="10" y="${H / 2}" text-anchor="middle" font-family="IBM Plex Mono" font-size="9" fill="var(--text-muted)" transform="rotate(-90 10 ${H/2})">CONFIDENCE →</text>
  `;
  const dots = pts.map(p => {
    const x = pad + (p.mat / 100) * (W - pad * 2);
    const y = H - pad - (p.conf / 100) * (H - pad * 2);
    return `<circle cx="${x}" cy="${y}" r="2.5" fill="${STATUS_META[p.status].color}" opacity="0.75"/>`;
  }).join('');

  wrap.innerHTML = `<svg width="100%" height="${H}" viewBox="0 0 ${W} ${H}">${axes}${dots}</svg>`;
}

function renderHeatmap() {
  const grid = document.getElementById('heatmapGrid');
  const buckets = ['0–20', '21–40', '41–60', '61–80', '81–100'];
  // Header row
  let html = `
    <div class="heatmap-row" style="grid-template-columns:160px repeat(${buckets.length},1fr);font-size:9px;color:var(--text-muted);font-family:var(--font-mono)">
      <span></span>${buckets.map(b => `<span style="text-align:center">${b}</span>`).join('')}
    </div>
  `;
  for (const tactic of TACTICS) {
    const techs = TECHNIQUES.filter(t => t.tactics.includes(tactic.id));
    const counts = [0, 0, 0, 0, 0];
    for (const t of techs) {
      const s = computeCoverage(state.coverage[t.id]);
      if (s <= 20) counts[0]++;
      else if (s <= 40) counts[1]++;
      else if (s <= 60) counts[2]++;
      else if (s <= 80) counts[3]++;
      else counts[4]++;
    }
    const max = Math.max(...counts, 1);
    const cells = counts.map((v, i) => {
      const intensity = v / max;
      const color = i === 0 ? `rgba(239,68,68,${0.15 + intensity * 0.7})` :
                    i === 1 ? `rgba(249,115,22,${0.15 + intensity * 0.7})` :
                    i === 2 ? `rgba(234,179,8,${0.15 + intensity * 0.7})` :
                    i === 3 ? `rgba(16,185,129,${0.15 + intensity * 0.7})` :
                              `rgba(16,185,129,${0.25 + intensity * 0.7})`;
      return `<div class="heatmap-cell" style="background:${v ? color : 'var(--bg-elevated)'};color:${v ? 'var(--text-primary)' : 'var(--text-faint)'}">${v || '·'}</div>`;
    }).join('');
    html += `
      <div class="heatmap-row" style="grid-template-columns:160px repeat(${buckets.length},1fr)">
        <span class="heatmap-label">${tactic.name}</span>
        ${cells}
      </div>
    `;
  }
  grid.innerHTML = html;
}


