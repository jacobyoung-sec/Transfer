          <span style="display:inline-flex;align-items:center;gap:4px"><span class="swatch" style="display:inline-block;width:8px;height:8px;border-radius:2px;background:var(--status-none)"></span>None</span>
          <span style="display:inline-flex;align-items:center;gap:4px"><span class="swatch" style="display:inline-block;width:8px;height:8px;border-radius:2px;background:var(--status-planned)"></span>Planned</span>
          <span style="display:inline-flex;align-items:center;gap:4px"><span class="swatch" style="display:inline-block;width:8px;height:8px;border-radius:2px;background:var(--status-fp)"></span>FP-prone</span>
