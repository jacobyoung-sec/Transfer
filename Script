# ---------- Parsing logic ----------

def parse_rights(rights_str: str) -> list:
    """Split a rights string like 'CCDCLCSWRPWPLOCRRCWDWO' into components."""
    if not rights_str:
        return []
    # Hex rights (e.g., 0x1f01ff) — return as-is with a note
    if rights_str.startswith("0x"):
        return [{"code": rights_str, "name": f"Hex rights mask {rights_str}", "dangerous": True}]
    # Two-character codes
    out = []
    i = 0
    while i < len(rights_str) - 1:
        code = rights_str[i:i+2]
        if code in RIGHTS:
            out.append({
                "code": code,
                "name": RIGHTS[code],
                "dangerous": code in DANGEROUS_RIGHTS,
            })
            i += 2
        else:
            # Unknown — capture and advance one char
            out.append({"code": code, "name": f"Unknown ({code})", "dangerous": False})
            i += 1
    return out


def resolve_sid(sid: str, domain_sid: Optional[str] = None) -> str:
    """Resolve a SID or SDDL abbreviation to a human-readable name."""
    if not sid:
        return "(none)"
    # Direct lookup
    if sid in WELL_KNOWN_SIDS:
        return WELL_KNOWN_SIDS[sid]
    # Domain-relative RID?
    if domain_sid and sid.startswith(domain_sid + "-"):
        rid = sid.rsplit("-", 1)[-1]
        if rid in DOMAIN_RID_NAMES:
            return f"{DOMAIN_RID_NAMES[rid]} ({sid})"
    # Bare RID pattern matching (if SID starts with S-1-5-21-)
    m = re.match(r"^S-1-5-21-\d+-\d+-\d+-(\d+)$", sid)
    if m:
        rid = m.group(1)
        if rid in DOMAIN_RID_NAMES:
            return f"{DOMAIN_RID_NAMES[rid]} ({sid})"
    return sid


def resolve_guid(guid: str) -> str:
    """Resolve an AD schema GUID to a friendly name."""
    if not guid:
        return ""
    g = guid.lower()
    return SCHEMA_GUIDS.get(g, guid)


def parse_ace(ace_body: str, domain_sid: Optional[str] = None) -> dict:
    """Parse a single ACE body (the contents between parens)."""
    parts = ace_body.split(";")
    # Pad to 6 fields
    while len(parts) < 6:
        parts.append("")
    ace_type, flags, rights, obj_guid, inherit_guid, sid = parts[:6]

    # Split flags into list
    flag_list = []
    if flags:
        for i in range(0, len(flags), 2):
            code = flags[i:i+2]
            flag_list.append(ACE_FLAGS.get(code, code))

    decoded_rights = parse_rights(rights)
    has_dangerous = any(r.get("dangerous") for r in decoded_rights)

    return {
        "type": ACE_TYPES.get(ace_type, ace_type),
        "type_code": ace_type,
        "flags": flag_list,
        "rights": decoded_rights,
        "rights_summary": ", ".join(r["name"] for r in decoded_rights),
        "object_guid": resolve_guid(obj_guid) if obj_guid else "",
        "inherit_object_guid": resolve_guid(inherit_guid) if inherit_guid else "",
        "trustee_sid": sid,
        "trustee_name": resolve_sid(sid, domain_sid),
        "contains_dangerous_rights": has_dangerous,
    }


def parse_sddl(sddl: str, domain_sid: Optional[str] = None) -> dict:
    """Parse a full SDDL string."""
    result = {
        "raw_sddl": sddl,
        "owner": None,
        "group": None,
        "dacl_flags": "",
        "sacl_flags": "",
        "aces": [],
        "dangerous_ace_count": 0,
    }

    # Parse top-level sections by walking the string.
    # SDDL structure: [O:owner][G:group][D:flags(aces)][S:flags(aces)]
    # Section boundaries are the markers O:, G:, D:, S: — but we must ignore
    # anything inside parentheses (ACE bodies can contain any characters).
    sections = []
    i = 0
    n = len(sddl)
    while i < n:
        # Look for a section marker: one of O/G/D/S followed by ':'
        if i + 1 < n and sddl[i] in "OGDS" and sddl[i+1] == ":":
            marker = sddl[i]
            j = i + 2
            paren_depth = 0
            # Advance j until we hit the next top-level section marker
            while j < n:
                ch = sddl[j]
                if ch == "(":
                    paren_depth += 1
                elif ch == ")":
                    paren_depth -= 1
                elif paren_depth == 0 and ch in "OGDS" and j + 1 < n and sddl[j+1] == ":":
                    break
                j += 1
            sections.append((marker, sddl[i+2:j]))
            i = j
        else:
            i += 1
    for marker, content in sections:
        content = content.strip()
        if marker == "O":
            result["owner"] = resolve_sid(content, domain_sid)
            result["owner_sid"] = content
        elif marker == "G":
            result["group"] = resolve_sid(content, domain_sid)
            result["group_sid"] = content
        elif marker in ("D", "S"):
            # Split into flag prefix and ACE bodies
            flag_match = re.match(r"^([^(]*)", content)
            flags = flag_match.group(1) if flag_match else ""
            ace_bodies = re.findall(r"\(([^)]*)\)", content)
            if marker == "D":
                result["dacl_flags"] = flags
                for ab in ace_bodies:
                    ace = parse_ace(ab, domain_sid)
                    ace["acl"] = "DACL"
                    result["aces"].append(ace)
                    if ace["contains_dangerous_rights"]:
                        result["dangerous_ace_count"] += 1
            else:
                result["sacl_flags"] = flags
                for ab in ace_bodies:
                    ace = parse_ace(ab, domain_sid)
                    ace["acl"] = "SACL"
                    result["aces"].append(ace)

    # Build summary text
    lines = []
    lines.append(f"Owner: {result['owner']}")
    lines.append(f"Group: {result['group']}")
    lines.append(f"DACL flags: {result['dacl_flags']}")
    lines.append(f"Total ACEs: {len(result['aces'])}")
    lines.append(f"ACEs with high-risk rights: {result['dangerous_ace_count']}")
    lines.append("")
    lines.append("=== ACE Breakdown ===")
    for i, ace in enumerate(result["aces"], 1):
        marker = " ⚠" if ace["contains_dangerous_rights"] else ""
        lines.append(f"[{i}] {ace['acl']} - {ace['type']}{marker}")
        lines.append(f"    Trustee: {ace['trustee_name']}")
        lines.append(f"    Rights:  {ace['rights_summary']}")
        if ace["object_guid"]:
            lines.append(f"    Object:  {ace['object_guid']}")
        if ace["flags"]:
            lines.append(f"    Flags:   {', '.join(ace['flags'])}")
    result["summary"] = "\n".join(lines)
    return result


# ---------- XSIAM entry point ----------

def main():
    sddl = demisto.args().get("sddl", "")
    domain_sid = demisto.args().get("domain_sid", None)

    if not sddl:
        return_error("Required argument 'sddl' is missing or empty.")
        return

    try:
        parsed = parse_sddl(sddl, domain_sid)
    except Exception as e:
        return_error(f"Failed to parse SDDL: {str(e)}")
        return

    # Build an XSIAM-friendly result with a markdown view and raw JSON context
    markdown = f"### Decoded Security Descriptor\n```\n{parsed['summary']}\n```"

    return_results(CommandResults(
        readable_output=markdown,
        outputs_prefix="SDDL",
        outputs_key_field="raw_sddl",
        outputs=parsed,
    ))


if __name__ in ("__builtin__", "builtins", "__main__"):
    main()
